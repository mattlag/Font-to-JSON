{
	"name": "font-flux-js",
	"version": "0.1.0",
	"description": "Convert a font file to JSON... and back!",
	"main": "src/main.js",
	"type": "module",
	"exports": {
		".": {
			"import": "./src/main.js"
		}
	},
	"files": [
		"dist/",
		"src/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"test:visual": "node test/visual/server.js",
		"build": "vite build",
		"docs:tables": "node scripts/generate-table-docs.mjs",
		"demo:dev": "vite --config demo/vite.config.js",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mattlag/Font-Flux-JS.git"
	},
	"keywords": [
		"font",
		"opentype",
		"truetype",
		"ttf",
		"otf",
		"json",
		"parser",
		"converter"
	],
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/mattlag/Font-Flux-JS/issues"
	},
	"homepage": "https://github.com/mattlag/Font-Flux-JS#readme",
	"devDependencies": {
		"vite": "^7.3.1",
		"vitepress": "1.6.4",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"pako": "^2.1.0"
	}
}
